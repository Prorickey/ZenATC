# Cloudflare CDN — domain serving HLS content
CLOUDFLARE_DOMAIN=zenatc.example.com

# Ed25519 private key (seed) for signing CDN URLs (base64-encoded, 32-byte seed).
# Generate one with:
#   go run ./scripts/genkey   (prints a fresh seed + matching public key)
# The backend signs with this; give the printed public key to the Cloudflare
# Worker as CLOUDFLARE_URL_SIGNING_PUBLIC_KEY.
CLOUDFLARE_URL_SIGNING_PRIVATE_KEY=

# HMAC-SHA256 secret for signing challenge JWTs (base64-encoded, 32+ bytes)
CHALLENGE_SIGNING_SECRET=

# Apple App ID — Team ID prefix + bundle identifier
APPLE_APP_ID=TEAMID.com.example.app

# SQLite database file for persisted device keys (defaults to zenatc.db next to the source)
ZENATC_DB_PATH=
